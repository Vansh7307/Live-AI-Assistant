# Copy to .env and fill values. NEVER commit the real .env file or paste
# real keys anywhere outside your local environment / secrets manager.
GOOGLE_API_KEY=...
TAVILY_API_KEY=...

# Optional
PORT=8000
GEMINI_MODEL=gemini-flash-latest
LOG_LEVEL=INFO

# Comma-separated frontend origins; use your production frontend URL when deploying.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Requests per window allowed on /chat, e.g. "20/minute". See slowapi docs
# for supported formats.
CHAT_RATE_LIMIT=20/minute

# Optional: if set, /chat requires a matching X-API-Key header. Strongly
# recommended once the API is reachable from the public internet.
APP_API_KEY=

# Optional: override the SQLite memory DB path (defaults to
# backend/memory/memory.sqlite3).
MEMORY_DB_PATH=
